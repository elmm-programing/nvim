{
	"coc.preferences.formatOnSaveFiletypes": [
		"css",
		"c#",
		"markdown",
		"graphql",
		"html",
		"yaml",
		"json",
		"python",
		"ejs",
		"hbs",
		"java",
		"javascript",
		"typescript",
		"typescriptreact"
	],
	"yaml.schemas": {
		"https://raw.githubusercontent.com/docker/compose/master/compose/config/config_schema_v2.0.json": "**/docker-compose*.yml"
	},
	"docker.enable": true,
	"languageserver": {
		"golang": {
			"command": "gopls",
			"rootPatterns": [
				"go.mod",
				".vim/",
				".git/",
				".hg/"
			],
			"filetypes": [
				"go"
			]
		}
	},
	//Java
	"java.enabled": true,
	"java.format.enabled": true,
	"java.completion.enabled": true,
	"java.autobuild.enabled": true,
	"java.format.settings.url": "/home/elmm/.config/nvim/eclipseFormatter.xml",
	"java.import.maven.enabled": true,
	"java.foldingRange.enabled": true,
	"java.implementationsCodeLens.enabled": true,
	"java.referencesCodeLens.enabled": true,
	"java.codeGeneration.generateComments": false,
	"java.import.gradle.enabled": true,
	"java.import.gradle.wrapper.enabled": true,
	//html
	"html.enable": true,
	"html.format.enable": true,
	"html.autoClosingTags": true,
	"html.suggest.html5": true,
	"html.validate.html": true,
	"snippets.ultisnips.directories": [
		"UltiSnips",
		"~/.config/nvim/utils/snips"
	],
  "Lua.telemetry.enable": false,
  "clangd.path": "~/.config/coc/extensions/coc-clangd-data/install/15.0.3/clangd_15.0.3/bin/clangd"
}
